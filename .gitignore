# =============================================
# Indoor Plant Assistant — Root .gitignore
# =============================================

# ─── Python ────────────────────────────────
__pycache__/
*.py[cod]
*.pyo
*.egg-info/
*.egg
dist/
build/
*.whl

# ─── Virtual Environments ──────────────────
venv/
.venv/
env/
.env

# ─── Node.js ───────────────────────────────
node_modules/
dist/
dist-ssr/

# ─── Environment & Secrets ─────────────────
.env
.env.*
!.env.example
*.local

# ─── AI Models (too large for Git) ─────────
*.keras
*.h5
*.tflite
*.pb
*.onnx
backend/app/ai/*.keras

# ─── Jupyter Notebooks (training artifacts) ─
backend/app/ai/*.ipynb

# ─── IDE ───────────────────────────────────
.vscode/
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# ─── OS Files ──────────────────────────────
.DS_Store
Thumbs.db

# ─── Logs & Debug Output ──────────────────
*.log
logs.txt
extract_output.txt
backend/out.txt
backend/out2.txt
npm-debug.log*
yarn-debug.log*
pnpm-debug.log*

# ─── Docker ────────────────────────────────
*.tar

# ─── Ngrok ─────────────────────────────────
ngrok.yml

# ─── Study Notes (personal, not source code)
part_1_general_knowledge.md
part_2_backend_code.md
part_2a_backend_foundation.md
part_2b1_api_crud_endpoints.md
part_2b2_scan_deep_dive.md
part_2c1_services_ai_weather.md
part_2c2_perenual_llm_admin.md
ai_model_plan.md
part_3*.md

# ─── Walkthrough / Internal Dev Notes ──────
walkthrough/
PROJECT_CONTEXT/
Bao_Cao_Tot_Nghiep/

# ─── Duplicate/Temp Folders ────────────────
backend/backend/
backend/venv/
backend/uploads/

# ─── Gemini Antigravity workspace ──────────
.gemini/
