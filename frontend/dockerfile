FROM node:20-alpine

WORKDIR /app

# Chỉ copy package files để tận dụng cache của Docker
COPY package.json package-lock.json* ./
RUN npm install

COPY . .

# Port mặc định cho Vite dev server
EXPOSE 5173

# Chạy Vite với flag --host để truy cập được từ ngoài container
CMD ["npm", "run", "dev", "--", "--host", "0.0.0.0", "--port", "5173"]